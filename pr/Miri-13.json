      "patch": "@@ -216,14 +216,18 @@ fn on_event_mouse(panes: &mut Panes, state: &DebuggerState, mouse: MouseEvent) {\n     }\n }\n \n+pub fn is_quit_event(event: &Event) -> bool {\n+    matches!(\n+        event,\n+        Event::Key(key)\n+            if key.kind == KeyEventKind::Press && key.code == KeyCode::Char('q')\n+    )\n+}\n+\n pub fn fast_quit() -> io::Result<bool> {\n     // Still allow immediate quit while fast-forwarding.\n-    if event::poll(Duration::from_millis(0))?\n-        && let Event::Key(key) = event::read()?\n-        && key.kind == KeyEventKind::Press\n-        && key.code == KeyCode::Char('q')\n-    {\n-        return Ok(true);\n+    if event::poll(Duration::from_millis(0))? {\n+        return Ok(is_quit_event(&event::read()?));\n     }\n     Ok(false)\n }"
    },
