      "raw_url": "https://github.com/KMiri-rs/miri/raw/420b4503038f12f76b98afac518e3634a24b0dcb/src%2Fmirch%2Fphysical_mem.rs",
      "contents_url": "https://api.github.com/repos/KMiri-rs/miri/contents/src%2Fmirch%2Fphysical_mem.rs?ref=420b4503038f12f76b98afac518e3634a24b0dcb",
      "patch": "@@ -131,10 +131,16 @@ pub fn type_pages_at<'tcx>(\n     page_type: TypedKind,\n ) -> InterpResult<'tcx, ()> {\n     let physical_mem = physical_mem_mut();\n+    let page_size = page_size();\n+    let page_state = PageState::Typed { page_type, slot_size };\n     for page_index in 0..count {\n-        let page_paddr = paddr + page_size() * page_index;\n-        physical_mem.set_page_state(page_paddr, PageState::Typed { page_type, slot_size });\n+        let page_paddr = paddr + page_size * page_index;\n+        physical_mem.set_page_state(page_paddr, page_state);\n     }\n+    // println!(\n+    //     \"[kern_miri_retype_pages] paddr=0x{paddr:x}..0x{:x} => {page_state:?}\",\n+    //     paddr + count * page_size\n+    // );\n \n     interp_ok(())\n }\n@@ -160,8 +166,12 @@ pub fn remove_init_mask(paddr: usize) {\n pub fn check_page_state(paddr: usize, page_state: PageState) {\n     let index = paddr / page_size();\n     let physical_mem = physical_mem();\n-    if physical_mem.page_states[index] != page_state {\n-        panic!(\"Page state UB: current page state is {:?}\", physical_mem.page_states[index]);\n+    let current = physical_mem.page_states[index];\n+    if current != page_state {\n+        panic!(\n+            \"Page state UB: current page (paddr=0x{paddr:x}, index={index}) state is {current:?}, \\\n+             while the expected should be {page_state:?}\"\n+        );\n     }\n }\n "
    },
