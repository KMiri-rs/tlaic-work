      "patch": "@@ -10,6 +10,12 @@ pub mod uart_ns16650a;\n \n /// Prints formatted arguments to the console.\n pub fn early_print(args: Arguments) {\n+    #[cfg(miri)]\n+    {\n+        miri_println!(\"{args}\");\n+        return;\n+    }\n+\n     let Some(serial) = SERIAL_PORT.get() else {\n         return;\n     };"
