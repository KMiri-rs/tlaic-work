      "patch": "@@ -80,7 +80,7 @@ impl<C: PageTableConfig> PageTableNode<C> {\n                 page.paddr(),\n                 1,\n                 crate::arch::PageType::PageTable,\n-                8,\n+                C::PTE_SIZE,\n             );\n         }\n "
    }
